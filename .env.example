# ─── Supabase (Project Settings → API) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
# Server-only: Inngest workers, janitor, pipeline (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Google OAuth (used for Classroom + Drive + refresh tokens) ─────────────
# Create OAuth 2.0 credentials in Google Cloud Console; add authorized redirect URIs
# for Supabase Auth and local dev (e.g. http://localhost:3000/auth/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google Gemini (Vercel AI SDK) ──────────────────────────────────────────
# API key for @ai-sdk/google — from Google AI Studio or Vertex, depending on setup.
GOOGLE_GENERATIVE_AI_API_KEY=

# ─── Inngest (local: run `npx inngest-cli@latest dev`) ─────────────────────
# Production: keys from Inngest dashboard → app → keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Optional: point the SDK at the local dev server (e.g. http://127.0.0.1:8288)
# INNGEST_BASE_URL=

# Optional: explicit app id (defaults are fine for most templates)
# INNGEST_APP_ID=multiagent-ai


# Together AI (Open-source model provider)
TOGETHER_API_KEY=